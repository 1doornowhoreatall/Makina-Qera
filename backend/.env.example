# Serveri
PORT=5000
NODE_ENV=development

# Baza e të dhënave PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=makina_qera
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME_TEST=makina_qera_test

# JWT
JWT_SECRET=makina-qera-secret-key-2024-ndryshoje-kete
